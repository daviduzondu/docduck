{
 "$schema": "https://turborepo.dev/schema.json",
 "ui": "tui",
 "tasks": {
  "build": {
   "dependsOn": [
    "^build"
   ],
   "inputs": [
    "$TURBO_DEFAULT$",
    ".env*"
   ],
   "outputs": [
    ".next/**",
    "!.next/cache/**"
   ]
  },
  "lint": {
   "dependsOn": [
    "^lint"
   ]
  },
  "check-types": {
   "dependsOn": [
    "^check-types"
   ]
  },
  "prisma": {
   "cache": false,
   "persistent": false
  },
  "migrate:dev": {
   "cache": false,
   "persistent": false,
   "interactive": true
  },
  "migrate:dev-apply": {
   "cache": false,
   "persistent": false,
   "interactive": true
  },
  "migrate:create-only": {
   "cache": false,
   "persistent": false,
   "interactive": true
  },
  "add:web": {
   "cache": false,
   "persistent": false
  },
  "add:server": {
   "cache": false,
   "persistent": false
  },
  "dev": {
   "cache": false,
   "persistent": true
  }
 }
}