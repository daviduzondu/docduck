// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator kysely {
 provider        = "prisma-kysely"
 output          = "./generated"
 fileName        = "types.ts"
 previewFeatures = ["partialIndexes"]
}

datasource db {
 provider = "postgresql"
}

model user {
 id            String  @id @unique @default(dbgenerated("gen_random_uuid()"))
 email         String  @unique
 emailVerified Boolean @default(false)
 name          String
 image         String?
 isAnonymous   Boolean @default(false)

 sessions session[]
 accounts account[]

 createdAt DateTime @ignore @db.Timestamptz(6)
 updatedAt DateTime @ignore @db.Timestamptz(6)

 documentInvitation document_invitation[]
 documentSnapshots  document_snapshot[]
 documentComments   document_comment[]
}

model session {
 id        String   @id @unique @default(dbgenerated("gen_random_uuid()"))
 userId    String
 token     String
 expiresAt DateTime
 ipAddress String?
 userAgent String?

 createdAt DateTime @default(now()) @ignore @db.Timestamptz(6)
 updatedAt DateTime @default(now()) @ignore @db.Timestamptz(6)

 // Relations
 user user @relation(fields: [userId], references: [id])
}

model account {
 id                    String    @id @unique @default(dbgenerated("gen_random_uuid()"))
 userId                String
 accountId             String // The ID of the account as provided by the SSO or equal to the userId for credential accounts
 providerId            String
 accessToken           String?
 refreshToken          String?
 accessTokenExpiresAt  DateTime?
 refreshTokenExpiresAt DateTime?
 scope                 String?
 idToken               String?
 password              String?

 createdAt DateTime @default(now()) @ignore @db.Timestamptz(6)
 updatedAt DateTime @default(now()) @ignore @db.Timestamptz(6)

 // Relations
 user user @relation(fields: [userId], references: [id])
}

model verification {
 id         String   @id @unique @default(dbgenerated("gen_random_uuid()"))
 identifier String
 token      String?
 expiresAt  DateTime

 createdAt DateTime @ignore @db.Timestamptz(6)
 updatedAt DateTime @ignore @db.Timestamptz(6)
}

model document {
 id               String     @id @unique @default(dbgenerated("gen_random_uuid()"))
 ownerId          String
 title            String     @default("Untitled Document")
 yjsState         Bytes?
 visibility       Visibility @default(PRIVATE)
 allowPublicEdits Boolean    @default(false)
 lastSnapshotAt   DateTime?  @db.Timestamptz(6)

 createdAt          DateTime              @default(now()) @ignore @db.Timestamptz(6)
 updatedAt          DateTime              @default(now()) @ignore @db.Timestamptz(6)
 documentInvitation document_invitation[]
 documentSnapshots  document_snapshot[]
 documentComments   document_comment[]

 @@index([ownerId])
}

model document_snapshot {
 id         String  @id @unique @default(dbgenerated("gen_random_uuid()"))
 documentId String
 yjsState   Bytes
 creatorId  String?
 name       String?

 createdAt DateTime @default(now()) @ignore @db.Timestamptz(6)
 updatedAt DateTime @default(now()) @ignore @db.Timestamptz(6)

 // relations
 document document @relation(fields: [documentId], references: [id])
 user     user?    @relation(fields: [creatorId], references: [id])

 @@index([documentId])
}

model document_invitation {
 id         String           @id @unique @default(dbgenerated("gen_random_uuid()"))
 email      String
 inviterId  String
 documentId String
 role       Role
 status     InvitationStatus @default(PENDING)
 acceptedAt DateTime?
 revokedAt  DateTime?
 createdAt  DateTime         @default(now()) @ignore @db.Timestamptz(6)
 updatedAt  DateTime         @default(now()) @ignore @db.Timestamptz(6)

 // Relations 
 inviter  user     @relation(fields: [inviterId], references: [id])
 document document @relation(fields: [documentId], references: [id])

 // \"status\"= 'PENDING' OR \"status\" = 'ACCEPTED' AND \"revokedAt\" IS NULL
 @@unique([email, documentId], where: raw("(\"status\" = 'PENDING' OR \"status\" = 'ACCEPTED') AND \"revokedAt\" IS NULL "), map: "unique_active_document_invitations_index")
}

model document_comment {
 id         String   @id @default(dbgenerated("gen_random_uuid()"))
 text       String
 parentId   String?
 userId     String
 documentId String
 resolved   Boolean  @default(false)
 createdAt  DateTime @default(now()) @db.Timestamptz(6)
 updatedAt  DateTime @default(now()) @db.Timestamptz(6)

 // Relations
 parent   document_comment?  @relation("CommentToReplies", fields: [parentId], references: [id])
 replies  document_comment[] @relation("CommentToReplies")
 document document           @relation(fields: [documentId], references: [id])
 user     user               @relation(fields: [userId], references: [id])
}

model permission {
 id         String   @id @unique @default(dbgenerated("gen_random_uuid()"))
 documentId String
 userId     String
 role       Role
 createdAt  DateTime @default(now()) @ignore @db.Timestamptz(6)
 updatedAt  DateTime @default(now()) @ignore @db.Timestamptz(6)

 @@unique([documentId, userId])
 @@index([userId])
 @@index([documentId])
}

enum Role {
 VIEWER
 EDITOR
 OWNER
}

enum Visibility {
 PRIVATE
 PUBLIC
}

enum InvitationStatus {
 PENDING
 ACCEPTED
 DECLINED
 REVOKED
}
